{
  "name": "anchor-edit",
  "version": "0.0.4",
  "description": "Stateful single-token anchored file editing (Dirac-style). MCP server via `anchor-edit mcp`.",
  "license": "MIT",
  "author": "Joilence <14588641+Joilence@users.noreply.github.com>",
  "homepage": "https://github.com/Joilence/anchor-edit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Joilence/anchor-edit.git"
  },
  "bugs": {
    "url": "https://github.com/Joilence/anchor-edit/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pi",
    "pi-package",
    "claude",
    "claude-code",
    "anchor-edit",
    "file-editing",
    "agent-tools"
  ],
  "type": "module",
  "bin": {
    "anchor-edit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "index.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.js"
    ]
  },
  "scripts": {
    "build": "bunup && chmod +x dist/bin.js",
    "build:pool": "bun run scripts/build-pool.ts",
    "link:pi": "pnpm run build && pi install \"$PWD\"",
    "unlink:pi": "pi remove \"$PWD\"",
    "dev": "bun --watch src/bin.ts",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^7.0.0",
    "js-tiktoken": "^1.0.21",
    "zod": "^4.3.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@mariozechner/pi-tui": "^0.72.1",
    "@types/bun": "^1.3.6",
    "@types/diff": "^7.0.2",
    "bunup": "^0.16.20",
    "typebox": "^1.1.24",
    "typescript": "~5.7.0"
  },
  "engines": {
    "node": ">=24"
  }
}
